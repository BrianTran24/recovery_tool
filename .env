# Development Environment
# Set ENABLE_FILE_ENCRYPTION to false for faster testing in dev
ENABLE_FILE_ENCRYPTION=true

# Encryption Keys (AES-256)
# Key must be 32 characters (256 bits), IV must be 16 characters (128 bits)
# IMPORTANT: Backup these keys! Without them, encrypted files cannot be decrypted
AES_ENCRYPTION_KEY=recovery-tool-secret-key-2026
AES_ENCRYPTION_IV=recovery-iv-2026x

# Backend API (development)
API_BASE_URL=http://localhost:3000
API_TIMEOUT=30
