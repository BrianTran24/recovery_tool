# Environment Configuration for Recovery Tool

# Enable/disable file encryption after recovery
# Set to false in development to skip encryption for faster testing
# Set to true in production to enable encryption
ENABLE_FILE_ENCRYPTION=true

# Encryption Keys (AES-256)
# Key must be 32 characters (256 bits), IV must be 16 characters (128 bits)
# Generate new keys using: see ENCRYPTION_KEYS.md
# IMPORTANT: Backup these keys! Without them, encrypted files cannot be decrypted
AES_ENCRYPTION_KEY=your-secret-encryption-key-32c
AES_ENCRYPTION_IV=your-secret-iv16

# Backend API Configuration
# API endpoint for premium verification
API_BASE_URL=https://api.example.com
API_TIMEOUT=30
